---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Articles | pete-builds" description="Articles on AI tools, automation, and practical infrastructure.">
  <h1>Articles</h1>
  <ul class="article-list" style="margin-top: 1.5rem;">
    {articles.map((article) => (
      <li>
        <a href={`/articles/${article.id}/`} class="article-title">{article.data.title}</a>
        <span class="article-date">
          {new Date(article.data.date + 'T00:00:00').toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </span>
        <p class="article-desc">{article.data.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>
